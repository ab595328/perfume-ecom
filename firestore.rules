rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if request is authenticated as an admin
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'admin@astraire.com' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Products Catalog Rules
    match /products/{productId} {
      // Anyone can view the catalog (Shop, ProductDetail, ScentQuiz)
      allow read: if true;
      // Only administrators can add, edit, or delete fragrance recipes
      allow write: if isAdmin();
    }

    // Orders Rules
    match /orders/{orderId} {
      // Admins can see all orders. Logged-in users can only view their own order logs.
      allow read: if isAdmin() || (request.auth != null && resource.data.user_email == request.auth.token.email);
      // Permitted for checkout (supports authenticated and guest checkouts)
      allow create: if true;
      // Only admins can modify order status (e.g., complete, void)
      allow update, delete: if isAdmin();
    }

    // Users Profile Registry Rules
    match /users/{userId} {
      // Users can view/edit their own profiles. Admins can access all registrants list.
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
